# ---- WhatsApp AI Chat Analyzer configuration ----

# Anthropic Claude API key (server-side only, never exposed to the browser)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used for classification
ANTHROPIC_MODEL=claude-sonnet-5

# Single-user app login
# Generate a hash with:  node server/dist/scripts/hash-password.js "your-strong-password"
# (or set APP_PASSWORD in dev to auto-hash on boot — NOT for production)
APP_PASSWORD_HASH=
APP_PASSWORD=

# Random 32+ char secret used to sign session cookies
SESSION_SECRET=change-me-to-a-long-random-string

# Encryption passphrase for the local database blob fields (PII, creds).
# If empty, at-rest field encryption is disabled (rely on full-disk encryption).
DATA_ENCRYPTION_KEY=

# Send redacted text to the cloud LLM (recommended: true)
REDACT_BEFORE_LLM=true

# Server
PORT=8787
NODE_ENV=production

# Data retention: auto-purge raw messages older than N days (0 = never)
RETENTION_DAYS=0

# ---- OPTIONAL live WhatsApp link (Baileys, pairing code) ----
# OFF by default. Enabling this uses the unofficial WhatsApp Web protocol and
# carries a real risk of your number being banned. Read docs plan §1 & §3 first.
# The client is strictly read-only. Requires: npm i baileys -w server
ENABLE_LIVE=false
